{
  "name": "ecp-dev",

  // compose.override.yml is generated by initializeCommand with backend-specific
  // flags (user mapping, socket GID, cgroup mounts). It is gitignored.
  "dockerComposeFile": ["compose.yml", "compose.override.yml"],
  "service": "dev",
  "workspaceFolder": "/workspace",

  // Keep the compose stack running across IDE reconnects; clean up on
  // "Close Remote Connection" / explicit container stop.
  "shutdownAction": "stopCompose",

  // Runs on the HOST before compose up.
  // Detects backend (podman vs docker), resolves dynamic values (socket path,
  // host UID/GID, docker socket GID), and writes:
  //   .devcontainer/.env                 — compose variable substitution
  //   .devcontainer/compose.override.yml — backend-specific runtime flags
  "initializeCommand": "${localWorkspaceFolder}/ci/scripts/devcontainer-init.sh",

  "customizations": {
    "vscode": {
      "extensions": ["golang.go"],
      "settings": {
        "go.gopath": "/workspace/.cache/go",
        "go.toolsGopath": "/workspace/.cache/go",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
