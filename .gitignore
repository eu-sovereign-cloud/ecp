# Go vendoring is intentionally disabled repo-wide. Ignore vendor directories
# at any depth so accidentally running `go mod vendor` / `go work vendor` in a
# module subdir does not pollute the working tree.
vendor/
/vendor/

# Go build outputs
*.exe
*.test
*.prof
*.pprof
*.out
*.log

# Local binaries and tools
kind
bin/
ci/tools/bin/

# IDE-specific files
/.kind/
/.work/
/.cache/
/.public/
/.vscode/
/.idea/

.DS_Store
scripts/common-template/dist/
/foundation/gateway/gateway

# Ignore local e2e context
/foundation/plugin/e2e/context/

# Devcontainer generated files (host-specific, written by devcontainer-init.sh)
/.devcontainer/.env
/.devcontainer/compose.override.yml
